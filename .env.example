# ─── Required ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here

# Auth token signing — MUST be 32+ random chars in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
VERIFY_SECRET=CHANGE_ME_TO_64_RANDOM_HEX_CHARS

# Email verification
RESEND_API_KEY=re_your_key_here

# ─── Security ───
# Comma-separated list of allowed origins (your frontend domain)
ALLOWED_ORIGINS=https://unigo-hk.vercel.app,https://your-custom-domain.com

# Only set in development — NEVER in production
# TEST_EMAIL=your-test@gmail.com
NODE_ENV=production
