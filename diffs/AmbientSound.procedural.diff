+
+function buildVoice(ctx: AudioContext, recipe: SceneRecipe, master: GainNode): SceneVoice {
+  // Lowpass filter — defines warmth. LFO modulates the cutoff slowly.
+  const filter = ctx.createBiquadFilter();
+  filter.type = 'lowpass';
+  filter.frequency.value = recipe.cutoffHz;
+  filter.Q.value = recipe.resonanceQ;
+
+  // LFO: slow oscillator → gain (depth) → filter.frequency
+  const lfo = ctx.createOscillator();
+  lfo.type = 'sine';
+  lfo.frequency.value = recipe.lfoHz;
+  const lfoGain = ctx.createGain();
+  lfoGain.gain.value = recipe.lfoDepthHz;
+  lfo.connect(lfoGain);
+  lfoGain.connect(filter.frequency);
+
+  // Per-voice (per-scene) gain — this is what we ramp for crossfades.
+  const gain = ctx.createGain();
+  gain.gain.value = 0;
+  filter.connect(gain);
+  gain.connect(master);
+
+  // Chord oscillators feed the filter.
+  const oscillators: OscillatorNode[] = [];
+  for (const interval of recipe.chord) {
+    const osc = ctx.createOscillator();
+    osc.type = recipe.oscType;
+    osc.frequency.value = recipe.rootHz * semitones(interval);
+    // Tiny detune per voice keeps the chord from sounding too clinical.
+    osc.detune.value = (Math.random() - 0.5) * 6;
+    // Per-oscillator trim so voices stack without clipping.
+    const oscGain = ctx.createGain();
+    oscGain.gain.value = 1 / recipe.chord.length;
+    osc.connect(oscGain);
+    oscGain.connect(filter);
+    oscillators.push(osc);
+  }
+
+  // Optional noise layer — blends through the same filter.
+  let noiseSource: AudioBufferSourceNode | null = null;
+  if (recipe.noiseColor !== 'none' && recipe.noiseGain > 0) {
+    noiseSource = ctx.createBufferSource();
+    noiseSource.buffer = makeNoiseBuffer(ctx, recipe.noiseColor);
+    noiseSource.loop = true;
+    const noiseGain = ctx.createGain();
+    noiseGain.gain.value = recipe.noiseGain;
+    noiseSource.connect(noiseGain);
+    noiseGain.connect(filter);
+  }
+
+  return { gain, oscillators, noiseSource, lfo, filter, started: false };
